           "note": "ACLS 2020: 1 мг IV болюсно, повтор каждые 3-5 мин (макс 3 мг)"}
        ]
      },
      "absolute_floor_mg": 0.3,
      "absolute_ceiling_mg": 50,
      "obsolete_doses": [
        {"value": "0.5 мг при брадикардии", "reason": "ACLS 2020: устаревшая, риск парадоксальной брадикардии. Теперь 1 мг."}
      ]
    },

