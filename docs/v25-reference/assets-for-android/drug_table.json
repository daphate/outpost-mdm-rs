  "comments": [
    "Каждый препарат — атомарная пропозиция: показания + диапазоны доз по путям введения + противопоказания.",
    "doses_by_indication: разные показания → разные диапазоны (анафилаксия vs СЛР для адреналина).",
    "absolute_floor_mcg / absolute_ceiling_mcg: нижний/верхний абсолютный порог. Доза ниже/выше — всегда CRITICAL.",
    "obsolete_doses: устаревшие или ОПАСНЫЕ дозы что нельзя писать (атропин 0.5 мг при брадикардии).",
    "tolerance: множитель допуска округления — 1.1 = ±10%.",
    "schema 1.1 (2026-05-10): добавлены source_docs[], valid_from; forbidden_field_procedures расширены по аудиту Codex (Foley в вену, ИПП-11 на ожог); налоксон-как-обезболивание блокируется forbidden_indications_pattern.",
    "ВСЕ цифры взяты из канонической карточки 00_quick_dose_reference_card.txt — НЕ ИЗМЕНЯТЬ без обновления корпуса."
  ],

  "drugs": {
    "TXA": {
      "patterns": ["\\bTXA\\b", "транексам", "транекс\\.\\s*кисл"],
      "indications": "массивное кровотечение, проникающее ранение туловища/конечности, любой шок, ампутация, артериальное",
      "doses_by_indication": {
        "массивное_кровотечение": [
          {"route": "iv|io", "min_mg": 2000, "max_mg": 2000, "tolerance": 1.0,
           "note": "CoTCCC 2024: 2 г IV/IO ОДНОКРАТНО медленным болюсом за 1 минуту. Старая схема 1+1 г/8ч УДАЛЕНА."},
          {"route": "im", "min_mg": 2000, "max_mg": 2000, "tolerance": 1.0,
           "note": "При недоступности IV/IO: 2 г IM (по 1 г в каждое бедро). CoTCCC 2024 уровень B."}
        ]
      },
      "absolute_floor_mg": 1000,
      "absolute_ceiling_mg": 4000,
      "time_window_hours": 3,
      "time_window_note": "ТОЛЬКО в первые 3 часа от ранения. После 3 часов — НЕ ВВОДИТЬ (CRASH-2: повышает смертность).",
      "forbidden_routes_strict": ["sc", "po", "intratheca"],
      "forbidden_pattern_in_text": "(?:txa|транексам)[^.]{0,60}?(?:в\\s+спинн|в\\s+сустав|интратека|сублингв)",
      "obsolete_doses": [
        {"value": "1 г + 1 г через 8 ч", "reason": "Удалено CoTCCC 2024, заменено на 2 г однократно"}
      ]
    },

    "адреналин": {
      "patterns": ["адренал", "эпинефрин", "эпине́рин", "epinephrin"],
      "indications": "анафилаксия, СЛР/остановка сердца, бронхоспазм, септический шок (TACEVAC)",
      "doses_by_indication": {
        "анафилаксия": [
          {"route": "im", "min_mg": 0.3, "max_mg": 0.5, "tolerance": 1.1,
           "context_pattern": "(?:анафилакс|укус|пчел|осы|шмел|оса\\b|отёк\\s+гортан|отёк\\s+квинке|круп|аллерг\\w*\\s+реакц)",
           "note": "Раствор 1:1000 в передне-латеральную часть бедра. Повтор каждые 5-15 мин."}
        ],
        "СЛР": [
          {"route": "iv|io", "min_mg": 1, "max_mg": 1, "tolerance": 1.1,
           "context_pattern": "(?:\\bслр\\b|\\bcpr\\b|остановк\\w*\\s+(?:сердц|кровообращен)|асистол|клиническ\\w*\\s+смерт|реаним\\w*\\s+сердц|нет\\s+пульса|пульса\\s+нет)",
           "note": "ACLS 2020: 1 мг IV/IO каждые 3-5 минут (без верхнего предела при остановке)"}
        ],
        "вазопрессор_TACEVAC": [
          {"route": "iv|io", "min_mcg_per_min": 2, "max_mcg_per_min": 10,
           "context_pattern": "(?:инфузи|капельно|вазопрессор|поддерж\\w*\\s+(?:давлен|АД)|септическ\\w*\\s+шок)",
           "note": "Инфузия 2-10 мкг/мин IV (госпитальный уровень)"}
        ],
        "педиатрия": [
          {"route": "im", "min_mg_per_kg": 0.01, "max_mg_per_kg": 0.01,
           "context_pattern": "(?:ребен|ребён|педиатр|возраст\\s+\\d+\\s+лет|для\\s+дет)",
           "note": "0.01 мг/кг IM (макс 0.3 мг для <30 кг, 0.5 мг >30 кг). EpiPen Jr 0.15 мг (15-30 кг), EpiPen 0.3 мг (>30 кг)"}
        ]
      },
      "absolute_floor_mcg": 100,
      "absolute_floor_note": "Меньше 100 мкг (0.1 мг) болюсно — ВСЕГДА ошибка. Анафилаксия требует ≥0.3 мг IM.",
      "absolute_ceiling_mg": 5,
      "obsolete_doses": [
        {"value": "1 мкг", "reason": "В 300-500 раз ниже терапевтической при анафилаксии — летально (h89)"}
      ]
    },

    "налоксон": {
      "patterns": ["налоксон", "naloxon", "налокса", "narcan"],
      "indications": "ОПИОИДНАЯ ПЕРЕДОЗИРОВКА (морфин, фентанил, промедол, героин). Угнетение дыхания после опиоидов. НЕ анальгетик. НЕ при шоке/кровотечении/анафилаксии.",
      "doses_by_indication": {
        "опиоидная_передозировка_iv": [
          {"route": "iv", "min_mg": 0.04, "max_mg": 0.4, "tolerance": 1.5,
           "context_pattern": "(?:опиоид|морфин|фентанил|героин|промедол.*передоз|трамадол.*передоз|передозиров|угнетен\\w*\\s+дыхан|миоз.*брадипн)",
           "note": "Титровать 0.04-0.4 мг IV до восстановления дыхания. Повтор каждые 2-3 мин до 10 мг."}
        ],
        "опиоидная_передозировка_im_in": [
          {"route": "im|in", "min_mg": 0.4, "max_mg": 2,
           "note": "0.4-2 мг IM/IN (Narcan назальный 4 мг IN). Длительность короткая 30-90 мин — мониторинг 2-4 часа!"}
        ]
      },
      "absolute_floor_mcg": 40,
      "absolute_ceiling_mg": 10,
      "forbidden_indications_pattern": "налоксон[^\\n]{0,120}?(?:анальгет|обезбол|для\\s+бол|при\\s+шок\\b|при\\s+кровотеч|при\\s+анафилакс|для\\s+снят\\w*\\s+бол|болеутол|вместо\\s+атропин|если\\s+есть\\s+анафилакс|есть\\s+анафилакс|анафилакс\\w*\\s*\\+|анафилакс[^\\n]{0,40}гипотенз)",
      "forbidden_severity": "critical",
      "forbidden_msg": "налоксон — АНТАГОНИСТ опиоидов (не анальгетик!), отменяет их обезболивающее действие. НЕ применяется при шоке/кровотечении/анафилаксии."
    },

    "атропин": {
